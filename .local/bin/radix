#!/usr/bin/env bash
# Convert between decimal, hex, and binary

if [[ $# -lt 1 ]]; then
  echo "Usage: radix <number>"
  echo "  radix 255    (decimal)"
  echo "  radix 0xff   (hex)"
  echo "  radix 0b1010 (binary)"
  exit 1
fi

input="$*"
input="${input// /}"

# Parse input to decimal
if [[ "$input" == 0b* ]]; then
  dec=$(( 2#${input#0b} ))
elif [[ "$input" == 0x* || "$input" == 0X* ]]; then
  dec=$(( 16#${input#0[xX]} ))
else
  dec=$(( 10#$input ))
fi

# Decimal and hex
hex=$(printf '0x%X' "$dec")

# Binary with nibble separators
bin=""
if [[ $dec -eq 0 ]]; then
  bin="0000"
else
  n=$dec
  while [[ $n -gt 0 ]]; do
    bin=$(( n & 1 ))$bin
    n=$(( n >> 1 ))
  done
  # Pad to multiple of 4
  while [[ $(( ${#bin} % 4 )) -ne 0 ]]; do
    bin="0$bin"
  done
fi

# Insert nibble separators
formatted=""
for (( i=0; i<${#bin}; i+=4 )); do
  [[ -n "$formatted" ]] && formatted+="'"
  formatted+="${bin:i:4}"
done

echo "dec: $dec"
echo "hex: $hex"
echo "bin: 0b$formatted"
